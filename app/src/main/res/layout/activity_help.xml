<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n初期設定ガイド（重要）"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FF5722"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Android 13 以上をお使いの方へ（重要）"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#E91E63"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Android 13以降でアプリをインストールした場合、セキュリティ制限により「通知アクセス」の設定がグレーアウトして選べない（または拒否される）ことがあります。\n\nその場合は、以下の「制限付き設定を解除」する操作が必ず必要です。\n\n【解除の手順】\n1. このアプリを一度閉じ、スマホの【設定】アプリを開きます。\n2. 【アプリ】→【すべてのアプリを表示】→【NotiTificationReader】を選びます。\n3. 画面の右上にある【︙】（点3つのメニュー）をタップします。\n4. 【制限付き設定を許可】を選びます。\n5. 本人確認（指紋やパスコード）をします。\n6. アプリに戻り、改めて「通知アクセス設定を開く」からスイッチをONにしてください。"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:textColor="#333333"
            android:background="#FFF3E0"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="通知アクセスの許可設定"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="通知アクセスが許可されていません　❌になっていたら、通知アクセス設定を開くボタンで、通知設定を開いてください。
            \n許可されたアプリにNotiTificationReaderが無ければ、下の許可されてないアプリ一覧からNotiTificationReaderを選び、画面が変わったら下にスクロールして、通知へのアクセスを許可のボタンをクリック。
            \nまた、画面が変わったら、下にスクロールして、”許可”をクリックしてください。通知へのアクセスを許可のボタンがONにたります。
            \n戻るボタンで戻って下さい。許可されたアプリにNotiTificationReaderが追加されました。
            \n戻るボタンで最初の画面に戻って下さい。通知アクセスが許可されています✅に変っています\n"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1.読み上げ間隔の設定"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="通知を読み上げて、次の通知を読むまでの時間を分秒で設定できます。\nON,OFFを短い間隔で繰り返す場合など、頻繁に同じ通知が来る場合など設定してください"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2.読み上げ停止時間の設定"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="開始時刻から終了時刻まで、指定した時間は読み上げをしません。終了が開始より小さいと、翌日の時間とします。"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3.読み上げるアプリの設定"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="通知を読み上げたいアプリにチェックを入れてください。"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:textColor="#333333" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4.キーワードフィルタ(全体)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="キーワードフィルタにキーワードを登録すると、キーワードが含まれない通知は読まれません。\n通知にキーワードがある場合は通知は読まれますが、キーワード自体は読まれません。"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5.キーワードフィルタ(個別)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="アプリのスパナマークをクリックすると、アプリ毎のキーワードが設定できます。キーワードが含まれない通知は読まれません。\n通知にキーワードが含まれる場合は通知は読まれますが、キーワード自体は読まれません。\n全体のキーワードより、アプリ毎のキーワードが優先されます。\n\n"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />



    </LinearLayout>
</ScrollView>
